generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────
// USERS (freelancers — synced from Supabase Auth)
// ─────────────────────────────────────

model User {
  id               String    @id // matches Supabase auth.users.id
  email            String    @unique
  name             String
  avatarUrl        String?   @map("avatar_url")
  brandName        String?   @map("brand_name")
  brandColor       String    @default("#6C5CE7") @map("brand_color")
  brandLogoUrl     String?   @map("brand_logo_url")
  plan             Plan      @default(FREE)
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  clients  Client[]
  projects Project[]
  invoices Invoice[]

  @@map("users")
}

enum Plan {
  FREE
  PRO
  UNLIMITED
}

// ─────────────────────────────────────
// CLIENTS (the freelancer's customers)
// ─────────────────────────────────────

model Client {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  email          String
  company        String?
  avatarUrl      String?   @map("avatar_url")
  portalSlug     String    @unique @map("portal_slug")
  magicLinkToken String?   @unique @map("magic_link_token")
  magicLinkExp   DateTime? @map("magic_link_exp")
  lastLogin      DateTime? @map("last_login")
  createdAt      DateTime  @default(now()) @map("created_at")

  projects Project[]
  invoices Invoice[]

  @@unique([userId, email])
  @@map("clients")
}

// ─────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────

model Project {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String        @map("client_id")
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      ProjectStatus @default(ACTIVE)
  progress    Int           @default(0)
  dueDate     DateTime?     @map("due_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  milestones Milestone[]
  files      ProjectFile[]
  activities Activity[]

  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  IN_REVIEW
  COMPLETED
  ON_HOLD
  OVERDUE
}

// ─────────────────────────────────────
// MILESTONES
// ─────────────────────────────────────

model Milestone {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  completed   Boolean   @default(false)
  dueDate     DateTime? @map("due_date")
  sortOrder   Int       @default(0) @map("sort_order")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("milestones")
}

// ─────────────────────────────────────
// FILES (metadata — actual files in Supabase Storage)
// ─────────────────────────────────────

model ProjectFile {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy  String       @map("uploaded_by")
  name        String
  storagePath String       @map("storage_path") // path in Supabase Storage
  mimeType    String       @map("mime_type")
  sizeBytes   Int          @map("size_bytes")
  category    FileCategory @default(DELIVERABLE)
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("project_files")
}

enum FileCategory {
  DELIVERABLE
  ASSET
  BRIEF
  CONTRACT
  OTHER
}

// ─────────────────────────────────────
// ACTIVITY LOG
// ─────────────────────────────────────

model Activity {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId   String    @map("actor_id")
  actorType ActorType @map("actor_type")
  action    String
  detail    String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([projectId, createdAt(sort: Desc)])
  @@map("activities")
}

enum ActorType {
  USER
  CLIENT
}

// ─────────────────────────────────────
// INVOICES
// ─────────────────────────────────────

model Invoice {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId         String        @map("client_id")
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNumber    String        @unique @map("invoice_number")
  status           InvoiceStatus @default(DRAFT)
  amountTotal      Decimal       @map("amount_total") @db.Decimal(10, 2)
  currency         String        @default("USD")
  dueDate          DateTime      @map("due_date")
  paidDate         DateTime?     @map("paid_date")
  stripeInvoiceId  String?       @unique @map("stripe_invoice_id")
  stripePaymentUrl String?       @map("stripe_payment_url")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  lineItems LineItem[]

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model LineItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  @@map("line_items")
}
